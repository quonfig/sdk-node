{
  "name": "@quonfig/node",
  "version": "0.0.25",
  "description": "Quonfig SDK for Node.js - Feature Flags, Live Config, and Dynamic Log Levels",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./winston": {
      "types": "./dist/integrations/winston.d.ts",
      "import": "./dist/integrations/winston.js",
      "require": "./dist/integrations/winston.cjs"
    },
    "./pino": {
      "types": "./dist/integrations/pino.d.ts",
      "import": "./dist/integrations/pino.js",
      "require": "./dist/integrations/pino.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-version.mjs",
    "build": "rm -rf dist/ && npx tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prettier": "prettier . -l",
    "prettier:fix": "prettier --write .",
    "version": "prettier --write CHANGELOG.md README.md && git add CHANGELOG.md README.md"
  },
  "keywords": [
    "quonfig",
    "feature-flags",
    "config",
    "remote-config",
    "feature-toggle"
  ],
  "author": "Quonfig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quonfig/sdk-node.git"
  },
  "homepage": "https://github.com/quonfig/sdk-node#readme",
  "bugs": {
    "url": "https://github.com/quonfig/sdk-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "eventsource": "^3.0.0",
    "murmurhash": "^2.0.1"
  },
  "peerDependencies": {
    "pino": ">=7.0.0",
    "winston": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "pino": {
      "optional": true
    },
    "winston": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "js-yaml": "^4.1.1",
    "pino": "9.14.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "winston": "3.19.0"
  }
}
